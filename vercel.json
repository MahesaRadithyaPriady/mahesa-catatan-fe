{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "node_modules/**",
      "use": "@vercel/static",
      "config": {
        "includeFiles": ["node_modules/sweetalert2/dist/sweetalert2.all.js"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
